{
  "name": "asset_allocator",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "electron:only": "cross-env NEXT_EXTERNAL_SERVER=1 electron .",
    "electron:dev": "concurrently -k \"npm run dev:webpack\" \"npm run electron:only\"",
    "seed": "npx tsx prisma/seed.ts",
    "sync:assets": "npx tsx scripts/sync-asset-metadata.ts",
    "build": "npx prisma generate && npx prisma migrate deploy && next build",
    "electron:builder": "electron-builder",
    "start": "next start",
    "lint": "eslint",
    "test": "cross-env NODE_ENV=test DATABASE_URL=file:./asset_allocator.test.db prisma db push --skip-generate && cross-env NODE_ENV=test DATABASE_URL=file:./asset_allocator.test.db vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.4.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
